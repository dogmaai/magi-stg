# OpenClaw memory backup — Box CCG credentials
# Copy this file to ~/.openclaw/.env on the server running "あか" and chmod 600.
#
#   cp .env.example ~/.openclaw/.env
#   chmod 600 ~/.openclaw/.env
#
# Required
BOX_CLIENT_ID=your_client_id
BOX_CLIENT_SECRET=your_client_secret
BOX_SUBJECT_ID=your_user_or_enterprise_id
BOX_FOLDER_ID=your_target_folder_id

# Optional
# "user" (default) for CCG as a managed user, "enterprise" for Service Account auth.
# BOX_SUBJECT_TYPE=user

# BACKUP_RETENTION_DAYS=7
# MEMORY_DB=/home/USER/.openclaw/memory/main.sqlite
# BACKUP_DIR=/home/USER/.openclaw/backup
# LOG_FILE=/home/USER/.openclaw/backup/backup.log
